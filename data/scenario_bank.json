  "base_scenarios": [
    {
      "name": "Turnaround Sprint",
      "context": "You are newly hired to revive a declining business unit within 90 days.",
      "competencies": ["prioritization", "financial diagnosis", "stakeholder management"],
      "stressor": "Board pressure and shrinking cash runway.",
      "evaluation_focus": ["clarity under pressure", "sequencing", "KPIs"]
    },
    {
      "name": "Expansion Dilemma",
      "context": "A profitable local brand is considering expansion into two new geographies.",
      "competencies": ["market entry", "risk assessment", "resource allocation"],
      "stressor": "Conflicting data from market research.",
      "evaluation_focus": ["hypothesis quality", "structured trade-offs", "decision rationale"]
    },
    {
      "name": "Digital Transformation",
      "context": "Legacy processes are slowing growth, and leadership wants AI-enabled redesign.",
      "competencies": ["change management", "operations design", "innovation strategy"],
      "stressor": "Employee resistance and limited technical talent.",
      "evaluation_focus": ["adoption strategy", "execution realism", "ROI thinking"]
    },
    {
      "name": "M&A Integration",
      "context": "Post-merger teams are fragmented and synergies are not materializing.",
      "competencies": ["integration planning", "culture alignment", "PMO governance"],
      "stressor": "Customer churn is rising during integration.",
      "evaluation_focus": ["cross-functional coordination", "value capture", "retention tactics"]
    }
  ],
